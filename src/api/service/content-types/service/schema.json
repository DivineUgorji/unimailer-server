{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "heading": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "slug": {
      "type": "uid"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.heading",
        "blocks.paragraph"
      ]
    },
    "serviceSignups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-signup.service-signup",
      "mappedBy": "service"
    }
  }
}
